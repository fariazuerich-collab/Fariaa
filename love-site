<div id="fx"></div>
#fx {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
}

.snow, .sparkle {
  position: absolute;
  animation: fall linear infinite;
}

.snow {
  width: 6px;
  height: 6px;
  background: white;
  border-radius: 50%;
  opacity: 0.7;
}

.sparkle {
  width: 4px;
  height: 4px;
  background: pink;
  border-radius: 50%;
  box-shadow: 0 0 10px pink;
}

